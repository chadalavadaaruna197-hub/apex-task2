<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Responsive Gallery Project</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
    <h1>Responsive Image Gallery</h1>
</header>

<nav>
    <a href="#gallery">Gallery</a>
    <a href="#contact">Contact</a>
</nav>

<main class="container">

    <!-- IMAGE GALLERY -->
    <section id="gallery">
        <h2>Image Gallery</h2>
        <div class="gallery-grid">
            <img src="https://picsum.photos/300?1" alt="Image 1">
            <img src="https://picsum.photos/300?2" alt="Image 2">
            <img src="https://picsum.photos/300?3" alt="Image 3">
            <img src="https://picsum.photos/300?4" alt="Image 4">
        </div>
    </section>

    <!-- CONTACT FORM -->
    <section id="contact">
        <h2>Contact Us</h2>
        <form id="contactForm">
            <input type="text" id="name" placeholder="Your Name">
            <span class="error" id="nameError"></span>

            <input type="email" id="email" placeholder="Your Email">
            <span class="error" id="emailError"></span>

            <button type="submit">Send</button>
        </form>
    </section>

</main>

<!-- MODAL -->
<div id="modal" class="modal">
    <span id="closeModal">&times;</span>
    <img id="modalImg">
</div>

<script src="script2.js"></script>
</body>
</html>
